<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Avalonia.Skia</AssemblyName>
    <RootNamespace>Avalonia.Skia</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <AssemblyOriginatorKeyFile>..\..\eng\Avalonia.snk</AssemblyOriginatorKeyFile>
    <AvaloniaAccessUnstablePrivateApis>true</AvaloniaAccessUnstablePrivateApis>
    <Avalonia_I_Want_To_Use_Private_Apis_IN_NUGET_PACKAGE>true</Avalonia_I_Want_To_Use_Private_Apis_IN_NUGET_PACKAGE>
    <AvaloniaForkRoot>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\external\Avalonia'))</AvaloniaForkRoot>
    <AvaloniaSkiaSourceRoot>$(AvaloniaForkRoot)\src\Skia\Avalonia.Skia</AvaloniaSkiaSourceRoot>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="$(AvaloniaSkiaSourceRoot)\**\*.cs"
             Exclude="$(AvaloniaSkiaSourceRoot)\GlyphRunImpl.cs">
      <Link>%(RecursiveDir)%(Filename)%(Extension)</Link>
    </Compile>
    <EmbeddedResource Include="$(AvaloniaSkiaSourceRoot)\Assets\NoiseAsset_256X256_PNG.png"
                      Link="Assets\NoiseAsset_256X256_PNG.png" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\SkiaSharp\SkiaSharp.csproj" />
    <PackageReference Include="Avalonia" />
  </ItemGroup>
  <ItemGroup Label="InternalsVisibleTo">
    <InternalsVisibleTo Include="Avalonia.SkiaShim.RenderTests, PublicKey=$(ProGPUPublicKey)" />
  </ItemGroup>
  <Target Name="ValidateAvaloniaForkSources" BeforeTargets="PrepareForBuild">
    <Error Condition="!Exists('$(AvaloniaSkiaSourceRoot)\DrawingContextImpl.cs')"
           Text="The pinned Avalonia source submodule is missing. Run 'git submodule update --init external/Avalonia'." />
  </Target>
</Project>
