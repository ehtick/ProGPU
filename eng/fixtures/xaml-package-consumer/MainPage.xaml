<Page
    x:Class="PackageConsumer.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PackageConsumer">
    <Page.Resources>
        <local:ConsumerModel
            x:Key="BindingSource"
            Title="Packaged resource source" />
    </Page.Resources>
    <StackPanel>
        <TextBlock
            x:Name="ResourceText"
            Text="{Binding Path=Title,
                           Source={StaticResource BindingSource}}" />
        <Button
            x:Name="ActionButton"
            Click="{x:Bind OnAction}"
            Content="{x:Bind Label}" />
    </StackPanel>
</Page>
